name: AI Code Review (Gemini)

on:
  pull_request:
    types: [opened, synchronize, reopened]

jobs:
  ai-review:
    runs-on: ubuntu-latest

    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
      GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}

      # === API ===
      GEMINI_MODEL: gemini-2.5-flash
      GEMINI_URL: https://generativelanguage.googleapis.com/v1beta/models

      # === Diff limits ===
      DIFF_MAX_BYTES: 30000

      # === Retry config ===
      MAX_RETRIES: 5
      BACKOFF_BASE_SECONDS: 2

      # === Prompt config ===
      MAX_COMMENTS: 10
      REVIEW_ROLE: senior C# reviewer

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Get diff (limited)
        run: |
          git fetch origin ${{ github.base_ref }}
          git diff origin/${{ github.base_ref }} > diff.txt
          head -c $DIFF_MAX_BYTES diff.txt > diff_small.txt

      - name: Build prompt
        run: |
          cat > prompt.txt <<EOF
          You are a $REVIEW_ROLE.
          
          Analyze the following git diff.
          
          Return ONLY valid JSON. No markdown. No explanation.
          
          Add short code suggestion or pattern to apply.
          
          Format:
          {
            "summary": "short overall review",
            "comments": [
              {
                "file": "path/file.cs",
                "line": 123,
                "comment": "text"
              }
            ]
          }
          
          Rules:
          - Focus on architecture issues, bugs, null issues, async issues
          - Detect hardcoded strings
          - Detect missing localization patterns
          - Suggest improvements
          - Max $MAX_COMMENTS comments
          EOF

      - name: Call Gemini API (with retry)
        run: |
          set -e

          jq -n \
            --arg prompt "$(cat prompt.txt)" \
            --arg diff "$(cat diff_small.txt)" \
            '{
              contents: [
                {
                  parts: [
                    {
                      text: ($prompt + "\n\nDIFF:\n" + $diff)
                    }
                  ]
                }
              ]
            }' > request.json

          URL="$GEMINI_URL/$GEMINI_MODEL:generateContent?key=$GEMINI_API_KEY"

          attempt=0

          until [ $attempt -ge $MAX_RETRIES ]
          do
            attempt=$((attempt+1))

            echo "Attempt $attempt of $MAX_RETRIES..."

            HTTP_CODE=$(curl -s -o response.json -w "%{http_code}" \
              -H "Content-Type: application/json" \
              -X POST \
              --data @request.json \
              "$URL")

            if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
              echo "Success on attempt $attempt"
              break
            fi

            echo "Request failed with HTTP $HTTP_CODE"

            if [ $attempt -eq $MAX_RETRIES ]; then
              echo "Max retries reached"
              exit 1
            fi

            sleep_time=$((BACKOFF_BASE_SECONDS ** attempt))
            echo "Retrying in $sleep_time seconds..."
            sleep $sleep_time

          done

      - name: Extract AI result safely
        run: |
          set -e

          jq -r '.candidates[0].content.parts[0].text // empty' response.json \
            | sed 's/```json//g' \
            | sed 's/```//g' \
            > ai_result.json

          if [ ! -s ai_result.json ]; then
            echo '{"summary":"No valid AI response, try again later.","comments":[]}' > ai_result.json
          fi

      - name: Post review comments
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');

            let raw = fs.readFileSync('ai_result.json', 'utf8');
            let data;

            try {
              data = JSON.parse(raw);
            } catch (e) {
              data = { summary: "AI returned invalid JSON", comments: [] };
            }

            const summary = data.summary ?? "Nothing from my side";
            const comments = Array.isArray(data.comments) ? data.comments : [];

            await github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: "🤖 AI Review:\n\n" + summary
            });

            const pr = await github.rest.pulls.get({
              owner: context.repo.owner,
              repo: context.repo.repo,
              pull_number: context.issue.number
            });

            for (const c of comments) {
              if (!c?.file || !c?.line || !c?.comment) continue;

              try {
                await github.rest.pulls.createReviewComment({
                  owner: context.repo.owner,
                  repo: context.repo.repo,
                  pull_number: context.issue.number,
                  body: c.comment,
                  commit_id: pr.data.head.sha,
                  path: c.file,
                  line: c.line,
                  side: "RIGHT"
                });
              } catch (e) {
                console.log("Failed to comment:", c);
              }
            }

      - name: Save AI artifacts
        run: |
          mkdir -p ai-output
          cp response.json ai-output/response.json || true
          cp ai_result.json ai-output/ai_result.json || true
          cp diff.txt ai-output/diff.txt || true

      - name: Upload artifacts
        uses: actions/upload-artifact@v4
        with:
          name: ai-code-review-${{ github.run_number }}
          path: ai-output/
          retention-days: 7